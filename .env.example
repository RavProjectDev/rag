# =============================================================================
# RAG System — Secret Environment Variables
# =============================================================================
#
# This file documents ONLY the secrets that must be provided at runtime.
# All non-secret configuration (DB names, regions, model choices, rate-limit
# values, URLs, etc.) lives in app/core/constants/ and does NOT belong here.
#
# Installation:
#   1. Copy this file: cp .env.example .env
#   2. Fill in every value below (no placeholders)
#   3. Install dependencies: pip install -r requirements.txt
#
# To change non-secret config (e.g. switch DB backend, tweak rate limits),
# edit the relevant file in app/core/constants/ instead.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# -----------------------------------------------------------------------------
# Google / Vertex AI
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: service-account JSON for Vertex AI (uses ADC if omitted)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# MongoDB connection URI (contains credentials — keep secret)
# Format: mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017

# Vector store
PINECONE_API_KEY=your_pinecone_api_key_here

# -----------------------------------------------------------------------------
# Auth (Supabase) — required when AUTH_MODE=prd
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -----------------------------------------------------------------------------
# Rate limiting (Upstash Redis) — omit to disable rate limiting
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
COHERE_API_KEY=your_cohere_api_key_here
